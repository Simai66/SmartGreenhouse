{
  "name": "smartgreenhouse-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute smartgreenhouse-db --local --file=./src/schema.sql",
    "db:init:remote": "wrangler d1 execute smartgreenhouse-db --file=./src/schema.sql",
    "db:seed": "wrangler d1 execute smartgreenhouse-db --local --file=./src/seed.sql"
  },
  "dependencies": {
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "wrangler": "^4.20.0",
    "typescript": "~6.0.2"
  }
}
